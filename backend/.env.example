APP_ENV=local
FCE_ENV=local
FCE_DEMO_MODE=false

# mock | bitget. FCE_DEMO_MODE=true overrides this with deterministic demo data.
MARKET_DATA_PROVIDER=mock
FCE_MARKET_DATA_PROVIDER=mock
DEFAULT_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,XRPUSDT,DOGEUSDT
FCE_DEFAULT_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,XRPUSDT,DOGEUSDT
CORS_ORIGINS=http://127.0.0.1:8876,http://localhost:8876
FCE_CORS_ORIGINS=http://127.0.0.1:8876,http://localhost:8876

# Database
DATABASE_URL=sqlite:///./fomo_control_engine.db
FCE_DATABASE_URL=sqlite:///./fomo_control_engine.db
FCE_DB_BACKUP_ENABLED=true
FCE_DB_BACKUP_DIR=./backups
FCE_DB_RETENTION_DAYS=30
FCE_DB_BACKUP_KEEP_DAYS=14
FCE_DB_TRADE_FILL_RETENTION_DAYS=2

# Bitget
BITGET_BASE_URL=https://api.bitget.com
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_API_PASSPHRASE=
FCE_BITGET_API_KEY=
FCE_BITGET_API_SECRET=
FCE_BITGET_API_PASSPHRASE=
BITGET_PRODUCT_TYPE=USDT-FUTURES
BITGET_MARGIN_COIN=USDT
BITGET_LOCALE=en-US
FCE_BITGET_PRODUCT_TYPE=USDT-FUTURES
FCE_BITGET_MARGIN_COIN=USDT
FCE_BITGET_LOCALE=en-US

# Live API test guard
RUN_LIVE_BITGET_TESTS=false
FCE_RUN_LIVE_BITGET_TESTS=false

# OpenAI
OPENAI_API_KEY=
FCE_OPENAI_API_KEY=
FCE_INSIGHT_MODEL=gpt-4.1-mini

# Worker
FCE_WORKER_ENABLED=true
FCE_WORKER_SYNC_POSITIONS_INTERVAL_SECONDS=90
FCE_WORKER_REFRESH_MARKET_DATA_INTERVAL_SECONDS=300
FCE_WORKER_REGEN_STALE_INSIGHTS_INTERVAL_SECONDS=120
FCE_WORKER_SCOUT_SCAN_ENABLED=true
FCE_WORKER_SCOUT_SCAN_INTERVAL_SECONDS=900
FCE_WORKER_CALIBRATION_CACHE_INTERVAL_SECONDS=1800
FCE_WORKER_SYMBOL_CATALOG_INTERVAL_SECONDS=86400

# Telegram
FCE_TELEGRAM_BOT_ENABLED=true
FCE_TELEGRAM_ALERTS_ENABLED=true
FCE_TELEGRAM_BOT_TOKEN=
FCE_TELEGRAM_CHAT_ID=
FCE_TELEGRAM_ALLOWED_CHAT_IDS=
FCE_TELEGRAM_QUIET_HOURS_ENABLED=true
FCE_TELEGRAM_QUIET_HOURS_START=01:00
FCE_TELEGRAM_QUIET_HOURS_END=08:00
FCE_TELEGRAM_QUIET_HOURS_TIMEZONE=Asia/Seoul
FCE_TELEGRAM_DAILY_SUMMARY_TIME=08:30

# Derivatives
FCE_DERIVATIVE_TRACKING_ENABLED=true
FCE_DERIVATIVE_TRACKING_INTERVAL_SECONDS=300
FCE_COINGLASS_API_KEY=
FCE_COINGLASS_RATE_LIMIT_PER_MINUTE=30

# Scout
FCE_SCOUT_WATCHLIST_SYMBOL_LIMIT=30
FCE_SCOUT_AUTO_ARM_ENABLED=true
FCE_SCOUT_MAX_ARMED_SETUPS_PER_SYMBOL=3
FCE_SCOUT_SETUP_NEAR_PCT=1.5

# Parameter autonomy
FCE_PARAM_AUTONOMY_ENABLED=true

# Performance
FCE_PERFORMANCE_CAPITAL_BASE_USDT=10000
FCE_PERFORMANCE_MONTHLY_MDD_LIMIT_PCT=0

# Backtest statistics (WO-36)
FCE_BACKTEST_TAKER_FEE_PCT=0.06
FCE_BACKTEST_DATA_QUALITY_FLOOR=70
FCE_BACKTEST_CACHE_TTL_HOURS=24
FCE_BACKTEST_BOOTSTRAP_ITERATIONS=1000
FCE_BACKTEST_OVERLAP_THRESHOLD=0.7
FCE_UNIVERSE_BACKTEST_MIN_CI_LOW_PCT=50
FCE_REGIME_MA_PERIOD=200
FCE_REGIME_ATR_HIGH_PERCENTILE=70

# Autonomous validation loop (WO-37)
FCE_AUTONOMY_ENABLED=true
FCE_AUTONOMY_WEEKLY_TRANSITION_CAP=5
FCE_DECAY_LIVE_DIVERGENCE_PCT=20
FCE_DECAY_LIVE_MIN_SAMPLE=15
FCE_SIGNATURE_VALIDATED_MIN_SAMPLE=30

# Lifecycle alerts (WO-44)
FCE_ALERT_PULSE_INTERVAL_HOURS=4
FCE_ALERT_CLOSURE_CONFIRM_TICKS=2
FCE_ALERT_EVIDENCE_INSUFFICIENT_HOURS=2
FCE_NOTIFICATION_STATE_PATH=./notification_state.json
