APP_ENV=local
FCE_ENV=local
FCE_DEMO_MODE=false

# mock | bitget. FCE_DEMO_MODE=true overrides this with deterministic demo data.
MARKET_DATA_PROVIDER=mock
FCE_MARKET_DATA_PROVIDER=mock
DEFAULT_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,XRPUSDT,DOGEUSDT
FCE_DEFAULT_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,XRPUSDT,DOGEUSDT
CORS_ORIGINS=http://127.0.0.1:8876,http://localhost:8876
FCE_CORS_ORIGINS=http://127.0.0.1:8876,http://localhost:8876

# Database
DATABASE_URL=sqlite:///./fomo_control_engine.db
FCE_DATABASE_URL=sqlite:///./fomo_control_engine.db
FCE_DB_BACKUP_ENABLED=true
FCE_DB_BACKUP_DIR=./backups
FCE_DB_RETENTION_DAYS=30
FCE_DB_BACKUP_KEEP_DAYS=14
FCE_DB_TRADE_FILL_RETENTION_DAYS=2

# Bitget
BITGET_BASE_URL=https://api.bitget.com
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_API_PASSPHRASE=
FCE_BITGET_API_KEY=
FCE_BITGET_API_SECRET=
FCE_BITGET_API_PASSPHRASE=

# Authenticated account fills for the read-only paper benchmark.
FCE_WORKER_USER_FILL_SYNC_ENABLED=true
FCE_WORKER_USER_FILL_SYNC_INTERVAL_SECONDS=120

# Temporary scored-candidate bridge; never bypasses N/win thresholds.
FCE_PAPER_CANDIDATE_BOOTSTRAP_ENABLED=true
FCE_PAPER_CANDIDATE_BOOTSTRAP_MIN_SAMPLE=15
FCE_PAPER_CANDIDATE_BOOTSTRAP_MIN_WIN_1R_PCT=50
FCE_PAPER_CANDIDATE_BOOTSTRAP_DISABLE_VALIDATED_COUNT=3
FCE_BITGET_TRADE_FILL_LOOKBACK_HOURS=96
FCE_BITGET_TRADE_FILL_MAX_ROWS=50000
FCE_BITGET_LIQUIDATION_HISTORY_ENABLED=true
FCE_BITGET_LIQUIDATION_HISTORY_PAGES=3
BITGET_PRODUCT_TYPE=USDT-FUTURES
BITGET_MARGIN_COIN=USDT
BITGET_LOCALE=en-US
FCE_BITGET_PRODUCT_TYPE=USDT-FUTURES
FCE_BITGET_MARGIN_COIN=USDT
FCE_BITGET_LOCALE=en-US

# Live API test guard
RUN_LIVE_BITGET_TESTS=false
FCE_RUN_LIVE_BITGET_TESTS=false

# OpenAI
OPENAI_API_KEY=
FCE_OPENAI_API_KEY=
FCE_INSIGHT_MODEL=gpt-4.1-mini

# Worker
FCE_WORKER_ENABLED=true
FCE_WORKER_SYNC_POSITIONS_INTERVAL_SECONDS=90
FCE_WORKER_REFRESH_MARKET_DATA_INTERVAL_SECONDS=300
FCE_WORKER_REGEN_STALE_INSIGHTS_INTERVAL_SECONDS=120
FCE_WORKER_SCOUT_SCAN_ENABLED=true
FCE_WORKER_SCOUT_SCAN_INTERVAL_SECONDS=900
FCE_WORKER_CALIBRATION_CACHE_INTERVAL_SECONDS=1800
FCE_WORKER_SYMBOL_CATALOG_INTERVAL_SECONDS=86400

# Toss Securities Open API stock observations (local worker only; read-only)
FCE_TOSS_STOCK_SCOUT_ENABLED=false
FCE_TOSS_CLIENT_ID=
FCE_TOSS_CLIENT_SECRET=
FCE_TOSS_BASE_URL=https://openapi.tossinvest.com
FCE_TOSS_TIMEOUT_SECONDS=10
FCE_TOSS_POLL_INTERVAL_SECONDS=10
FCE_TOSS_KR_WATCHLIST=
FCE_TOSS_US_WATCHLIST=AAPL,MSFT,NVDA

# Stock paper track (separate from crypto; PaperBroker only)
FCE_STOCK_PAPER_ENGINE_ENABLED=true
# Permanent seal for this WO. Setting true intentionally prevents startup.
FCE_STOCK_LIVE_TRADING_ENABLED=false
FCE_STOCK_PAPER_INITIAL_KRW=100000000
FCE_STOCK_PAPER_INITIAL_USD=100000
FCE_STOCK_PAPER_MAX_MINUTE_VOLUME_RATIO=0.05
FCE_STOCK_PAPER_KR_COMMISSION_RATE=0.00015
FCE_STOCK_PAPER_US_COMMISSION_RATE=0.0007
FCE_STOCK_PAPER_KR_SELL_TAX_RATE=0.0015

# Telegram
FCE_TELEGRAM_BOT_ENABLED=true
FCE_TELEGRAM_ALERTS_ENABLED=true
FCE_TELEGRAM_BOT_TOKEN=
FCE_TELEGRAM_CHAT_ID=
FCE_TELEGRAM_ALLOWED_CHAT_IDS=
FCE_TELEGRAM_QUIET_HOURS_ENABLED=true
FCE_TELEGRAM_QUIET_HOURS_START=01:00
FCE_TELEGRAM_QUIET_HOURS_END=08:00
FCE_TELEGRAM_QUIET_HOURS_TIMEZONE=Asia/Seoul
FCE_TELEGRAM_DAILY_SUMMARY_TIME=08:30

# Derivatives
FCE_DERIVATIVE_TRACKING_ENABLED=true
FCE_DERIVATIVE_TRACKING_INTERVAL_SECONDS=300
FCE_COINGLASS_API_KEY=
FCE_COINGLASS_RATE_LIMIT_PER_MINUTE=30
FCE_COINGLASS_REQUESTS_PER_SYMBOL=10
FCE_OCC_OPTIONS_ENABLED=true
FCE_OCC_OPTIONS_CACHE_TTL_SECONDS=1800
FCE_OCC_OPTIONS_TIMEOUT_SECONDS=10

# Hyperliquid public whale observation (read only, no signing)
FCE_HYPERLIQUID_WHALE_TRACKING_ENABLED=true
FCE_HYPERLIQUID_WHALE_DISCOVERY_ENABLED=true
FCE_HYPERLIQUID_WHALE_DISCOVERY_INTERVAL_SECONDS=3600
FCE_HYPERLIQUID_WHALE_DISCOVERY_MIN_ACCOUNT_USD=1000000
FCE_HYPERLIQUID_WHALE_DISCOVERY_MIN_MONTH_PNL_USD=100000
FCE_HYPERLIQUID_WHALE_DISCOVERY_MIN_MONTH_ROI=0.02
FCE_HYPERLIQUID_WHALE_DISCOVERY_MIN_MONTH_VOLUME_USD=10000000
FCE_HYPERLIQUID_WHALE_DISCOVERY_MAX_TURNOVER=250
FCE_HYPERLIQUID_WHALE_DISCOVERY_SCAN_LIMIT=120
FCE_HYPERLIQUID_WHALE_DIRECTIONAL_SLOTS=8
FCE_HYPERLIQUID_WHALE_FOCUS_SYMBOLS=BTC,ETH
FCE_HYPERLIQUID_WHALE_POLL_INTERVAL_SECONDS=30
FCE_HYPERLIQUID_WHALE_ALERT_BATCH_WINDOW_SECONDS=180
FCE_HYPERLIQUID_WHALE_MIN_SIZE_USD=100000
FCE_HYPERLIQUID_WHALE_MAX_WALLETS=20
FCE_HYPERLIQUID_WHALE_INITIAL_LOOKBACK_HOURS=168
FCE_HYPERLIQUID_REQUEST_TIMEOUT_SECONDS=10

# Scout
FCE_SCOUT_WATCHLIST_SYMBOL_LIMIT=30
FCE_SCOUT_TRACKING_SYMBOL_LIMIT=10
FCE_SCOUT_AUTO_ARM_ENABLED=true
FCE_SCOUT_MAX_ARMED_SETUPS_PER_SYMBOL=3
FCE_SCOUT_SETUP_NEAR_PCT=1.5

# Parameter autonomy
FCE_PARAM_AUTONOMY_ENABLED=true

# Performance
FCE_PERFORMANCE_CAPITAL_BASE_USDT=10000
FCE_PERFORMANCE_MONTHLY_MDD_LIMIT_PCT=0

# Deterministic paper benchmark (read-only; never sends exchange orders)
FCE_PAPER_ENGINE_ENABLED=true
FCE_PAPER_MARGIN_USDT=100
FCE_PAPER_LEVERAGE=3
FCE_PAPER_MAX_OPEN_POSITIONS=5
FCE_PAPER_MIN_EVIDENCE=4
FCE_PAPER_MIN_CHECKLIST_PASSED=5
FCE_PAPER_MIN_RR=1.5
FCE_PAPER_MAX_HOLDING_BARS=30
FCE_PAPER_TAKE_PROFIT_ATR_K1=1.0
FCE_PAPER_TAKE_PROFIT_ATR_K2=2.0
FCE_PAPER_POOR_MDD_PCT=10
FCE_PAPER_TELEGRAM_ALERTS_ENABLED=true

# Backtest statistics (WO-36)
FCE_BACKTEST_TAKER_FEE_PCT=0.06
FCE_BACKTEST_DATA_QUALITY_FLOOR=70
FCE_BACKTEST_CACHE_TTL_HOURS=24
FCE_BACKTEST_BOOTSTRAP_ITERATIONS=1000
FCE_BACKTEST_OVERLAP_THRESHOLD=0.7
FCE_UNIVERSE_BACKTEST_MIN_CI_LOW_PCT=50
FCE_UNIVERSE_STAGE2_GATE_ENABLED=true
FCE_REGIME_MA_PERIOD=200
FCE_REGIME_ATR_HIGH_PERCENTILE=70

# Autonomous validation loop (WO-37)
FCE_AUTONOMY_ENABLED=true
FCE_AUTONOMY_WEEKLY_TRANSITION_CAP=5
FCE_DECAY_LIVE_DIVERGENCE_PCT=20
FCE_DECAY_LIVE_MIN_SAMPLE=15
FCE_SIGNATURE_VALIDATED_MIN_SAMPLE=30

# Lifecycle alerts (WO-44)
FCE_ALERT_PULSE_INTERVAL_HOURS=4
FCE_ALERT_CLOSURE_CONFIRM_TICKS=2
FCE_ALERT_EVIDENCE_INSUFFICIENT_HOURS=2
FCE_NOTIFICATION_STATE_PATH=./notification_state.json
# Polymarket public-data paper track (no wallet/auth/live orders)
FCE_POLYMARKET_PAPER_ENABLED=true
FCE_POLYMARKET_POLL_INTERVAL_SECONDS=60
FCE_POLYMARKET_INITIAL_USDC=10000
FCE_POLYMARKET_GAMMA_BASE_URL=https://gamma-api.polymarket.com
FCE_POLYMARKET_CLOB_BASE_URL=https://clob.polymarket.com
FCE_POLYMARKET_TIMEOUT_SECONDS=10
FCE_POLYMARKET_MARKET_LIMIT=100
